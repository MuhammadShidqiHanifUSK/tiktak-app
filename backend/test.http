### ✅ Test server
GET http://localhost:5000

### ========== AUTH ==========

### Register guru
POST http://localhost:5000/api/auth/register
Content-Type: application/json

{
  "nama": "Hanif",
  "email": "hanif@gmail.com",
  "password": "hanif123"
}

### Login guru
POST http://localhost:5000/api/auth/login
Content-Type: application/json

{
  "email": "hanif@gmail.com",
  "password": "hanif123"
}

### ========== KELAS ==========

### Tambah kelas
POST http://localhost:5000/api/kelas/
Content-Type: application/json

{
  "guru_id": 1,
  "nama_kelas": "Kelas 3A",
  "tingkatan": "3"
}

### Ambil semua kelas guru
GET http://localhost:5000/api/kelas/?guru_id=1

### Hapus kelas
DELETE http://localhost:5000/api/kelas/1

### ========== SISWA ==========

### Tambah siswa
POST http://localhost:5000/api/siswa/
Content-Type: application/json

{
  "kelas_id": 1,
  "nama": "Budi Santoso"
}

### Ambil semua siswa
GET http://localhost:5000/api/siswa/?kelas_id=1

### Update level siswa
PUT http://localhost:5000/api/siswa/1/level
Content-Type: application/json

{
  "level_kemampuan": 2
}

### Hapus siswa
DELETE http://localhost:5000/api/siswa/1

### ========== SOAL ==========

### Tambah soal
POST http://localhost:5000/api/soal/
Content-Type: application/json

{
  "cerita": "Pak Budi berangkat ke sawah pagi-pagi bersama anaknya menggunakan sepeda pada pukul 06.30. Mereka melewati sungai dan hutan, hingga tibalah mereka di sawah pada pukul 07.00.",
  "jawaban_jam": 7,
  "jawaban_menit": 0,
  "tingkat_kesulitan": 1
}

### Ambil soal level 1
GET http://localhost:5000/api/soal/?tingkat=1

### Hapus soal
DELETE http://localhost:5000/api/soal/1

### ========== SESI ==========

### Submit jawaban benar
POST http://localhost:5000/api/sesi/
Content-Type: application/json

{
  "siswa_id": 1,
  "soal_id": 1,
  "jawaban_jam": 7,
  "jawaban_menit": 0,
  "waktu_respons": 8.5,
  "jumlah_koreksi": 1,
  "jumlah_ulang_audio": 0
}

### Submit jawaban salah
POST http://localhost:5000/api/sesi/
Content-Type: application/json

{
  "siswa_id": 1,
  "soal_id": 1,
  "jawaban_jam": 6,
  "jawaban_menit": 30,
  "waktu_respons": 15.2,
  "jumlah_koreksi": 3,
  "jumlah_ulang_audio": 2
}

### Riwayat sesi siswa
GET http://localhost:5000/api/sesi/siswa/1

### ========== DASHBOARD ==========

### Ringkasan kelas
GET http://localhost:5000/api/dashboard/kelas/1

### Detail performa siswa
GET http://localhost:5000/api/dashboard/siswa/1

### Siswa perlu perhatian
GET http://localhost:5000/api/dashboard/perhatian/

### Evaluasi 1 - Beni senam
POST http://localhost:5000/api/soal/
Content-Type: application/json

{
    "cerita": "Setiap hari Sabtu, Beni mengikuti senam pagi bersama teman-temannya. Senam dimulai pukul 07.00 dan senam berlangsung selama 45 menit. Setelah berolahraga, guru mengajak semua siswa minum air putih dan makan buah pisang yang telah dibawa dari rumah. Guru menjelaskan bahwa olahraga yang rutin dan makanan bergizi membantu tubuh menjadi kuat sehingga tidak mudah sakit. Pukul berapa senam selesai?",
    "jawaban_jam": 7,
    "jawaban_menit": 45,
    "tingkat_kesulitan": 1,
    "jenis": "evaluasi"
}

### Evaluasi 2 - Salsa makan siang
POST http://localhost:5000/api/soal/
Content-Type: application/json

{
    "cerita": "Salsa selalu membawa bekal dari rumah. Hari ini ia membawa nasi, ayam, tumis wortel, dan jeruk. Saat waktu makan siang pukul 12.00, Salsa makan bersama teman-temannya selama 25 menit. Guru menjelaskan bahwa makanan bergizi seimbang terdiri atas makanan pokok, lauk, sayur, buah, dan air putih. Dengan makanan yang bergizi, tubuh menjadi lebih sehat dan siap mengikuti kegiatan belajar. Pukul berapa Salsa selesai makan?",
    "jawaban_jam": 0,
    "jawaban_menit": 25,
    "tingkat_kesulitan": 1,
    "jenis": "evaluasi"
}

### Evaluasi 3 - Dito istirahat
POST http://localhost:5000/api/soal/
Content-Type: application/json

{
    "cerita": "Saat cuaca sangat panas, guru mengingatkan siswa untuk banyak minum air putih. Pada waktu istirahat pukul 10.00, Dito bermain bersama teman-temannya selama 30 menit. Setelah bermain, Dito langsung minum air putih sebelum masuk kelas kembali. Pukul berapa Dito minum air putih setelah bermain?",
    "jawaban_jam": 10,
    "jawaban_menit": 30,
    "tingkat_kesulitan": 1,
    "jenis": "evaluasi"
}

### Evaluasi 4 - Siska tidur
POST http://localhost:5000/api/soal/
Content-Type: application/json

{
    "cerita": "Malam hari, Siska belajar mulai pukul 19.30 hingga pukul 20.30. Setelah menyiapkan buku untuk esok hari, ia langsung tidur satu jam kemudian. Keesokan paginya, Siska bangun dengan tubuh segar dan siap berangkat ke sekolah. Pukul berapa Siska mulai tidur?",
    "jawaban_jam": 9,
    "jawaban_menit": 30,
    "tingkat_kesulitan": 1,
    "jenis": "evaluasi"
}